<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center">

            <!-- ==================== ACCELEROMETER CARD ==================== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center_horizontal">

                    <!-- Card title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📱 Accelerometer"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorPrimary"
                        android:layout_marginBottom="4dp" />

                    <!-- Sensor availability status -->
                    <TextView
                        android:id="@+id/textAccStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Checking..."
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurface"
                        android:alpha="0.6"
                        android:layout_marginBottom="12dp"
                        android:textAlignment="center" />

                    <!-- X axis value -->
                    <TextView
                        android:id="@+id/textAccX"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="X (left/right):      -- m/s²"
                        android:textSize="15sp"
                        android:fontFamily="monospace"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="6dp" />

                    <!-- Y axis value -->
                    <TextView
                        android:id="@+id/textAccY"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Y (forward/back):  -- m/s²"
                        android:textSize="15sp"
                        android:fontFamily="monospace"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="6dp" />

                    <!-- Z axis value -->
                    <TextView
                        android:id="@+id/textAccZ"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Z (up/down):         -- m/s²"
                        android:textSize="15sp"
                        android:fontFamily="monospace"
                        android:textColor="?attr/colorOnSurface" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ==================== LIGHT SENSOR CARD ==================== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center_horizontal">

                    <!-- Card title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡 Light Sensor"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorPrimary"
                        android:layout_marginBottom="4dp" />

                    <!-- Sensor availability status -->
                    <TextView
                        android:id="@+id/textLightStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Checking..."
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurface"
                        android:alpha="0.6"
                        android:layout_marginBottom="12dp"
                        android:textAlignment="center" />

                    <!-- Light value -->
                    <TextView
                        android:id="@+id/textLight"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Intensity: -- lux"
                        android:textSize="16sp"
                        android:textColor="?attr/colorOnSurface" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ==================== PROXIMITY SENSOR CARD ==================== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center_horizontal">

                    <!-- Card title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📏 Proximity Sensor"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorPrimary"
                        android:layout_marginBottom="4dp" />

                    <!-- Sensor availability status -->
                    <TextView
                        android:id="@+id/textProxStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Checking..."
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurface"
                        android:alpha="0.6"
                        android:layout_marginBottom="12dp"
                        android:textAlignment="center" />

                    <!-- Proximity value -->
                    <TextView
                        android:id="@+id/textProximity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Distance: -- cm"
                        android:textSize="16sp"
                        android:textColor="?attr/colorOnSurface" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
